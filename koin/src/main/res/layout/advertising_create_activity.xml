<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:ignore="MissingPrefix">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <in.koreatech.koin.core.bases.KoinBaseAppbarDark
                android:id="@+id/koin_base_app_bar_dark"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:left_button_background="@drawable/ic_back_arrow"
                app:title_text="홍보게시판" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="56dp"
                android:layout_marginBottom="56dp"
                android:orientation="vertical">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:scrollbarAlwaysDrawVerticalTrack="true"
                    app:layout_constrainedHeight="true"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintVertical_bias="0">


                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/advertising_create_layout"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="1000dp"
                            android:orientation="vertical"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <Button
                                android:id="@+id/advertising_create_activity_store_button"
                                android:layout_width="179dp"
                                android:layout_height="29dp"
                                android:layout_marginLeft="16dp"
                                android:layout_marginTop="15dp"
                                android:background="@drawable/bg_black_rectangle"
                                android:lineSpacingExtra="2sp"
                                android:text="노랑통닭"
                                android:textColor="#69717a"
                                android:textSize="13sp" />


                            <TextView
                                android:id="@+id/textView"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="제목을 입력해주세요(최대 20자)"
                                android:textSize="16sp"
                                android:textColorHint="#e7e7e7"
                                android:letterSpacing="-0.05"
                                android:lineSpacingExtra="2sp"
                                android:layout_marginTop="19dp"
                                android:layout_marginBottom="19dp"
                                />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:orientation="horizontal"
                                android:background="@color/divider"
                                ></LinearLayout>

                            <TextView
                                android:id="@+id/textView9"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="16sp"
                                android:textColorHint="#e7e7e7"
                                android:letterSpacing="-0.05"
                                android:lineSpacingExtra="2sp"
                                android:hint="홍보 문구를 입력해주세요.(최대 50자)"
                                android:layout_marginTop="19dp"
                                android:layout_marginBottom="19dp"
                                />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:orientation="horizontal"
                                android:background="@color/divider">

                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="59dp"
                                android:orientation="horizontal"
                                >

                                <LinearLayout
                                    android:orientation="horizontal"
                                    android:layout_width="149dp"
                                    android:layout_height="30dp"
                                    android:layout_marginLeft="16dp"
                                    android:layout_marginTop="14dp"
                                    >
                                    <ImageView
                                        android:id="@+id/advertising_calender_imageview"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:layout_marginTop="1dp"
                                        app:srcCompat="@drawable/ic_calendar" />

                                    <TextView
                                        android:id="@+id/advertising_create_calender_startdate_textview"
                                        android:layout_marginTop="8dp"
                                        android:layout_marginBottom="7dp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="2019.09.01" />

                                </LinearLayout>

                                <TextView
                                    android:id="@+id/textView14"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="~"
                                    android:textSize="13sp"
                                    android:textColor="@color/light_navy"
                                    android:lineSpacingExtra="4sp"
                                    tools:text="~"
                                    android:layout_marginTop="18dp"
                                    android:layout_marginBottom="18dp"
                                    android:layout_marginLeft="11dp"
                                    />

                                <LinearLayout
                                    android:layout_width="149dp"
                                    android:layout_height="30dp"
                                    android:layout_marginLeft="10dp"
                                    android:layout_marginTop="14dp"
                                    android:orientation="horizontal"


                                    >

                                    <ImageView
                                        android:id="@+id/imageView"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:layout_marginTop="1dp"
                                        app:srcCompat="@drawable/ic_calendar" />

                                    <TextView
                                        android:id="@+id/textView10"
                                        android:layout_marginTop="8dp"
                                        android:layout_marginBottom="7dp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="2019.09.01"
                                        />
                                </LinearLayout>


                            </LinearLayout>

                            

                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>


                </ScrollView>


            </RelativeLayout>
        </RelativeLayout>

        <include layout="@layout/base_navigation_bar_bottom" />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>


    <include layout="@layout/base_navigation_drawer_left" />


</androidx.drawerlayout.widget.DrawerLayout>
